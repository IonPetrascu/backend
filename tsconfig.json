{
  "compilerOptions": {
    "target": "ES2020",

    // NodeNext — современный ESM режим для Node.js.
    // Prisma 7 генерирует ESM код, поэтому переключаемся с CommonJS на ESM.
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
